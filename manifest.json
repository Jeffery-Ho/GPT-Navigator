{
  "manifest_version": 3,
  "name": "Polaris for Web",
  "version": "0.3.1",
  "version_name": "0.3.1 build 10",
  "description": "Show H1-H3 heading markers for ChatGPT and Doubao answers and jump to headings from the right edge.",
  "key": "",
  "icons": {
    "16": "icons/gpt-voyager-icon-16.png",
    "32": "icons/gpt-voyager-icon-32.png",
    "48": "icons/gpt-voyager-icon-48.png",
    "128": "icons/gpt-voyager-icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://www.doubao.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/gpt-voyager-icon-96.png"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.doubao.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.doubao.com/*"
      ],
      "js": [
        "src/config.js",
        "src/content.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
